generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  firstName String   @map("first_name")
  lastName  String   @map("last_name")  // No código TS: firstName | No DB: first_name
  email     String   @unique
  password  String

  refreshToken String? @map("refresh_token")

  products Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")  // Define o nome da tabela no PostgreSQL como 'users'
}

model Product {
  id           String   @id @default(uuid())
  name         String
  brand        String?
  model        String?
  size         String?
  purchaseDate DateTime?
  price        Decimal?
  notes        String?

  userId String
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}